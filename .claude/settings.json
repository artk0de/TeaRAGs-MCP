{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__git-global__git_commit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/confirm-git-commit.sh",
            "statusMessage": "Validating git commit (must show changes summary first)"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-plugin-version.sh",
            "statusMessage": "Checking plugin version bump"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-auto-push.sh",
            "statusMessage": "Checking git push authorization"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Edit|Write) && tool_input.file_path matches \"^.*(src/|benchmarks/).*$\"",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-docs-needed.sh",
            "statusMessage": "Checking if documentation update needed"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-mcp-schema.sh",
            "statusMessage": "Validating MCP tool schema"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__git-global__git_commit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-release-scope.sh",
            "statusMessage": "Checking release scope configuration"
          }
        ]
      }
    ],
    "Stop": []
  }
}
