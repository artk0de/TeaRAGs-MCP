#!/bin/bash

# Run beads sync if available (optional - contributors may not have bd)
if command -v bd >/dev/null 2>&1; then
  bd hook pre-commit "$@" 2>/dev/null || true
fi

# Format and lint staged .ts/.js files
if ! npx lint-staged 2>&1; then
  echo ""
  echo "============================================"
  echo "  lint-staged failed (ESLint or Prettier)"
  echo "============================================"
  echo ""
  echo "If ESLint --fix could not auto-fix the issue:"
  echo "  1. Read the error message above"
  echo "  2. Fix the code manually (do NOT change eslint.config.js)"
  echo "  3. Stage the fix: git add <file>"
  echo "  4. Retry the commit"
  echo ""
  echo "Common fixes:"
  echo "  - no-floating-promises  → add 'await' or 'void' before the promise"
  echo "  - no-unused-vars        → remove the unused variable/import"
  echo "  - eqeqeq                → use === instead of =="
  echo "  - consistent-type-imports → add 'type' keyword to type-only imports"
  echo ""
  exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# ─── Plugin versioning check ───────────────────────────────────────────────
# If .claude-plugin/ files changed, plugin.json must be bumped too
for plugin_dir in .claude-plugin/tea-rags .claude-plugin/tea-rags-setup; do
  plugin_name=$(basename "$plugin_dir")
  plugin_json="$plugin_dir/.claude-plugin/plugin.json"
  # Check if any files in this plugin are staged (excluding plugin.json itself)
  plugin_files=$(echo "$STAGED_FILES" | grep "^${plugin_dir}/" | grep -v ".claude-plugin/plugin.json" || true)
  if [ -n "$plugin_files" ]; then
    # Check if plugin.json is also staged
    json_staged=$(echo "$STAGED_FILES" | grep "^${plugin_json}$" || true)
    if [ -z "$json_staged" ]; then
      echo ""
      echo "============================================"
      echo "  Plugin version bump required: $plugin_name"
      echo "============================================"
      echo ""
      echo "Files changed in $plugin_dir/ but $plugin_json was not updated."
      echo "Bump the version (patch for text changes, minor for new files),"
      echo "then stage it: git add $plugin_json"
      echo ""
      exit 1
    fi
    # Check marketplace.json is in sync with plugin.json
    marketplace_json=".claude-plugin/marketplace.json"
    marketplace_staged=$(echo "$STAGED_FILES" | grep "^${marketplace_json}$" || true)
    if [ -z "$marketplace_staged" ]; then
      echo ""
      echo "============================================"
      echo "  Marketplace version sync required: $plugin_name"
      echo "============================================"
      echo ""
      echo "$plugin_json was bumped but $marketplace_json was not updated."
      echo "Update the version for '$plugin_name' in marketplace.json to match,"
      echo "then stage it: git add $marketplace_json"
      echo ""
      exit 1
    fi
  fi
done

# Check if src/ files changed
SRC_CHANGED=$(echo "$STAGED_FILES" | grep -E "^src/" || true)

# Check if TypeScript/JavaScript files changed
TS_FILES=$(echo "$STAGED_FILES" | grep -E "\.(ts|tsx|js|jsx)$" || true)

# Determine what needs to run
RUN_TESTS=""
RUN_TYPECHECK=""

if [ -n "$SRC_CHANGED" ]; then
  RUN_TESTS=1
else
  echo "⏭️  No src/ changes, skipping tests"
fi

if [ -n "$TS_FILES" ]; then
  RUN_TYPECHECK=1
else
  echo "⏭️  No TypeScript changes, skipping type check"
fi

# Run type-check first (fast), then tests — sequential to avoid vitest fork timeouts
if [ -n "$RUN_TYPECHECK" ]; then
  echo "🔍 Running type check..."
  npm run type-check || { echo "❌ Type check failed"; exit 1; }
fi

if [ -n "$RUN_TESTS" ]; then
  echo "📦 Running tests with coverage check..."
  TEST_OUTPUT=$(npm test -- --run --coverage --reporter=verbose 2>&1)
  TEST_EXIT=$?
  if [ $TEST_EXIT -ne 0 ]; then
    echo "$TEST_OUTPUT" | grep -E "FAIL|×|Error|failed|threshold"
    echo ""
    echo "❌ Tests or coverage threshold failed. Run 'npx vitest run' for details."
    exit 1
  else
    echo "$TEST_OUTPUT" | tail -3
  fi
fi
