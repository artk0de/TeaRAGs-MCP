{
  "name": "dinopowers",
  "description": "Wrapper skills over superpowers:* that inject tea-rags signals (risk, ownership, churn, impact) into brainstorming, planning, execution, debugging, and review flows",
  "version": "0.13.1",
  "author": { "name": "artk0de" },
  "keywords": [
    "superpowers",
    "wrapper",
    "tea-rags",
    "git-signals",
    "risk-assessment",
    "data-driven"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-wrapper-routing.sh"
          }
        ]
      }
    ]
  }
}
